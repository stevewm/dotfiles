{{- $username := promptStringOnce . "username" "Username" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}

[user]
	name = {{ $ username }}
	email = {{ $email | quote }}
[init]
	defaultBranch = main
[color]
	ui = auto
[merge]
  ff = only
[push]
	autoSetupRemote = true
[pull]
  rebase = true
[url "ssh://git@github.com/"]
  pushInsteadOf = https://github.com/
